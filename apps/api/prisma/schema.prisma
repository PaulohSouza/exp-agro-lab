// EXP-AGROLAB — schema inicial (Marco 0).
// Ver SDD/04-design-detalhado/01-modelo-dados.md
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// ----------------------------- Multi-tenancy ----------------------------- 

model Instituicao {
  id                String   @id @default(cuid())
  nome              String
  cnpj              String?
  politicaAprovacao PoliticaAprovacao @default(todos)
  nAprovadores      Int      @default(1)
  ativo             Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  unidades     Unidade[]
  departamentos Departamento[]
  usuarios     User[]
  experimentos Experimento[]
  aprovadores  AprovadorInstituicao[]
  modelosAvaliacao ModeloAvaliacao[]
  gruposColeta GrupoColeta[]
  modelosAtividade ModeloAtividade[]
}

enum PoliticaAprovacao {
  todos
  n_de_m
}

// Departamento agrupa unidades/laboratórios dentro da instituição (RF-21b).
model Departamento {
  id            String   @id @default(cuid())
  instituicaoId String
  nome          String
  ativo         Boolean  @default(true)
  createdAt     DateTime @default(now())
  instituicao   Instituicao @relation(fields: [instituicaoId], references: [id])
  unidades      Unidade[]
  usuarios      User[]
  modelosAvaliacao ModeloAvaliacao[]
  gruposColeta  GrupoColeta[]
  modelosAtividade ModeloAtividade[]

  @@index([instituicaoId])
}

model Unidade {
  id            String   @id @default(cuid())
  instituicaoId String
  departamentoId String?
  nome          String
  tipo          TipoUnidade @default(unidade)
  ativo         Boolean  @default(true)
  instituicao   Instituicao @relation(fields: [instituicaoId], references: [id])
  departamento  Departamento? @relation(fields: [departamentoId], references: [id])
  usuarios      User[]
  experimentos  Experimento[]
}

enum TipoUnidade {
  unidade
  laboratorio
}

model User {
  id                 String   @id @default(cuid())
  instituicaoId      String
  unidadeId          String?
  departamentoId     String?
  nome               String
  email              String   @unique
  senhaHash          String
  papel              Papel    @default(analista)
  // Mantido por retrocompatibilidade na fatia 1; papel é a nova fonte da verdade. @see RN-RBAC
  isAdminInstituicao Boolean  @default(false)
  ativo              Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  instituicao        Instituicao @relation(fields: [instituicaoId], references: [id])
  unidade            Unidade?    @relation(fields: [unidadeId], references: [id])
  departamento       Departamento? @relation(fields: [departamentoId], references: [id])
  experimentosOwner  Experimento[] @relation("ExperimentoOwner")
  compartilhamentos  ExperimentoCompartilhamento[] @relation("CompartilhadoCom")
  responsavelEm      ExperimentoResponsavel[] @relation("ResponsavelColeta")
  aprovadorEm        AprovadorInstituicao[]
}

// Papéis com escopo (RN-RBAC). admin_sistema é GLOBAL (cross-institution).
enum Papel {
  admin_sistema
  gestao_instituicao
  gestao_departamento
  coordenador_area
  pesquisador
  analista
  assistente
}

// ----------------------------- Cadastros base ---------------------------- 

model Categoria {
  id    String @id @default(cuid())
  nome  String
  ativo Boolean @default(true)
  subcategorias Subcategoria[]
}

model Subcategoria {
  id          String @id @default(cuid())
  categoriaId String
  nome        String
  ativo       Boolean @default(true)
  categoria   Categoria @relation(fields: [categoriaId], references: [id])
  objetos     ObjetoEstudo[]
}

model ObjetoEstudo {
  id             String @id @default(cuid())
  subcategoriaId String
  nome           String
  obs            String?
  ativo          Boolean @default(true)
  subcategoria   Subcategoria @relation(fields: [subcategoriaId], references: [id])
  experimentos   Experimento[]
}

model Local {
  id           String @id @default(cuid())
  nome         String
  experimentos Experimento[]
}

model Safra {
  id           String @id @default(cuid())
  nome         String
  experimentos Experimento[]
}

model AreaPesquisa {
  id           String @id @default(cuid())
  nome         String
  experimentos Experimento[]
}

model Delineamento {
  id           String @id @default(cuid())
  nome         String
  experimentos Experimento[]
}

// ------------------------------ Experimento ------------------------------ 

model Experimento {
  id               String   @id @default(cuid())
  codigo           String?
  titulo           String
  objetivo         String?  @db.Text
  ensaio           Ensaio   @default(interno)
  status           StatusExperimento @default(Inserindo)

  instituicaoId    String
  unidadeId        String?
  ownerId          String
  objetoEstudoId   String?
  localId          String?
  safraId          String?
  areaPesquisaId   String?
  delineamentoId   String?

  cultivar         String?
  tipoExecucao     String?
  metodologia      String?  @db.Text
  justificativa    String?  @db.Text
  observacoes      String?  @db.Text

  parcelaLarguraM     Float?
  parcelaComprimentoM Float?
  parcelaNumLinhas    Int?
  espacamentoLinhasM  Float?
  numRepeticoes       Int?
  numTratamentos      Int?
  totalParcelas       Int?

  previsaoSemeadura DateTime?
  dataSemeadura     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  instituicao   Instituicao   @relation(fields: [instituicaoId], references: [id])
  unidade       Unidade?      @relation(fields: [unidadeId], references: [id])
  owner         User          @relation("ExperimentoOwner", fields: [ownerId], references: [id])
  objetoEstudo  ObjetoEstudo? @relation(fields: [objetoEstudoId], references: [id])
  local         Local?        @relation(fields: [localId], references: [id])
  safra         Safra?        @relation(fields: [safraId], references: [id])
  areaPesquisa  AreaPesquisa? @relation(fields: [areaPesquisaId], references: [id])
  delineamento  Delineamento? @relation(fields: [delineamentoId], references: [id])

  fatores         Fator[]
  tratamentos     Tratamento[]
  parcelas        Parcela[]
  avaliacoes      Avaliacao[]
  atividades      AtividadeExperimento[]
  timings         Timing[]
  compartilhamentos ExperimentoCompartilhamento[]
  responsaveis    ExperimentoResponsavel[]
  ordensServico   OrdemServico[]
  statusHistorico StatusHistorico[]

  @@index([instituicaoId])
  @@index([ownerId])
}

// Responsável pela COLETA de dados de um experimento (pesquisador/analista/
// assistente atribuído). Define o escopo "atribuídos" no painel. @see RN-RBAC
model ExperimentoResponsavel {
  id            String   @id @default(cuid())
  experimentoId String
  userId        String
  createdAt     DateTime @default(now())
  experimento   Experimento @relation(fields: [experimentoId], references: [id], onDelete: Cascade)
  user          User        @relation("ResponsavelColeta", fields: [userId], references: [id])

  @@unique([experimentoId, userId])
  @@index([userId])
}

enum Ensaio {
  interno
  comercial
}

enum StatusExperimento {
  Inserindo
  AprovadoCAD
  RecusadoCAD
  EmConducao
  Concluido
}

model Fator {
  id            String @id @default(cuid())
  experimentoId String
  ordem         Int
  nome          String
  tipo          TipoFator @default(qualitativo)
  experimento   Experimento @relation(fields: [experimentoId], references: [id], onDelete: Cascade)
  niveis        NivelFator[]
}

enum TipoFator {
  qualitativo
  quantitativo
}

model NivelFator {
  id      String @id @default(cuid())
  fatorId String
  valor   String
  rotulo  String?
  fator   Fator @relation(fields: [fatorId], references: [id], onDelete: Cascade)
}

model Tratamento {
  id            String @id @default(cuid())
  experimentoId String
  numeroRef     Int
  tag           String?
  nome          String?
  descricao     String? @db.Text
  experimento   Experimento @relation(fields: [experimentoId], references: [id], onDelete: Cascade)
  parcelas      Parcela[]
  produtos      TratamentoProduto[]
}

// Cadastros de produtos/atividades e timings do experimento
model Produto {
  id    String @id @default(cuid())
  nome  String
  marca String?
  ativo Boolean @default(true)
  usos  TratamentoProduto[]
}

model Atividade {
  id         String @id @default(cuid())
  nome       String
  valorVenda Float?
  ativo      Boolean @default(true)
  usos       TratamentoProduto[]
}

model Timing {
  id            String @id @default(cuid())
  experimentoId String
  nome          String
  ordem         Int    @default(0)
  experimento   Experimento @relation(fields: [experimentoId], references: [id], onDelete: Cascade)
  usos          TratamentoProduto[]
  avaliacoes    Avaliacao[]
}

// Produto aplicado em um tratamento (linha da aba Tratamentos do print)
model TratamentoProduto {
  id             String @id @default(cuid())
  tratamentoId   String
  seq            Int     @default(1)
  produtoId      String
  modoAplicacao  String?
  dose           Float?
  unidadeDose    String?
  volumeCaldaLha Float?
  referencia     String?
  timingId       String?
  atividadeId    String?
  descricao      String? @db.Text
  tratamento     Tratamento @relation(fields: [tratamentoId], references: [id], onDelete: Cascade)
  produto        Produto    @relation(fields: [produtoId], references: [id])
  timing         Timing?    @relation(fields: [timingId], references: [id])
  atividade      Atividade? @relation(fields: [atividadeId], references: [id])

  @@index([tratamentoId])
}

model Parcela {
  id            String @id @default(cuid())
  experimentoId String
  tratamentoId  String
  bloco         Int
  numero        Int
  posLinha      Int
  posColuna     Int
  isInicio      Boolean @default(false)
  experimento   Experimento @relation(fields: [experimentoId], references: [id], onDelete: Cascade)
  tratamento    Tratamento  @relation(fields: [tratamentoId], references: [id])
  dados         AvaliacaoDado[]

  @@index([experimentoId])
}

// ------------------------------ Avaliações ------------------------------- 

model Avaliacao {
  id            String @id @default(cuid())
  experimentoId String
  modeloId      String?            // origem no catálogo (null = ad-hoc)
  grupoColetaId String?            // grupo de coleta de origem (filtro de coleta)
  nome          String
  metodologia   String? @db.Text
  descricaoColeta String? @db.Text // como a coleta é feita (herdado do modelo, sobreponível)
  numeroPontos  Int     @default(1) // pontos amostrais (sobrepõe o do modelo)
  unidadeColeta String?
  unidadeSaida  String?
  formula       String?
  tipo          TipoAvaliacao @default(calendarizada)
  personalizada Boolean @default(false)
  escala        String?
  timingId      String?
  dataPrevista  DateTime?
  ordem         Int     @default(0)
  experimento   Experimento @relation(fields: [experimentoId], references: [id], onDelete: Cascade)
  modelo        ModeloAvaliacao? @relation(fields: [modeloId], references: [id])
  grupoColeta   GrupoColeta?     @relation(fields: [grupoColetaId], references: [id])
  timing        Timing?  @relation(fields: [timingId], references: [id])
  dados         AvaliacaoDado[]

  @@index([modeloId])
  @@index([grupoColetaId])
}

enum TipoAvaliacao {
  calendarizada
  condicional
}

// ----------------------- Catálogo de avaliações (multi-escopo) -----------------------
// Modelo reutilizável de avaliação. Existe em três escopos: padrão do sistema,
// padrão da instituição (só admin da instituição cadastra) e metodologia própria
// do departamento/laboratório. A mesma medida (ex.: "Altura de plantas") pode ter
// versões distintas em cada escopo. Ver SDD/04-design-detalhado/08-catalogo-avaliacoes.md
model ModeloAvaliacao {
  id                   String  @id @default(cuid())
  nome                 String
  descricaoColeta      String? @db.Text  // como a coleta é feita
  numeroPontos         Int     @default(1) // pontos amostrais coletados
  metodologiaRelatorio String? @db.Text  // base para a IA redigir o relatório
  unidadeColeta        String?            // ex.: kg
  unidadeSaida         String?            // ex.: sacas/ha
  calculoRelatorio     String?            // fórmula de conversão
  escopo               EscopoModelo @default(sistema)
  instituicaoId        String?            // dono quando escopo = instituicao/departamento
  departamentoId       String?            // dono quando escopo = departamento
  baseadoEmId          String?            // derivado de outro modelo (ex.: depto herda do sistema)
  ativo                Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  instituicao   Instituicao?  @relation(fields: [instituicaoId], references: [id])
  departamento  Departamento? @relation(fields: [departamentoId], references: [id])
  baseadoEm     ModeloAvaliacao?  @relation("ModeloDerivacao", fields: [baseadoEmId], references: [id])
  derivados     ModeloAvaliacao[] @relation("ModeloDerivacao")

  prerequisitos ModeloAvaliacaoPrereq[] @relation("ModeloPrereqs")     // avaliações que este exige
  requeridoPor  ModeloAvaliacaoPrereq[] @relation("ModeloRequeridoPor") // avaliações que exigem este
  prerequisitosAtividade ModeloAvaliacaoPrereqAtividade[] @relation("AvalReqAtiv") // atividades que este exige

  avaliacoes    Avaliacao[]
  gruposItens   GrupoColetaItem[]

  @@index([escopo])
  @@index([instituicaoId])
  @@index([departamentoId])
}

enum EscopoModelo {
  sistema
  instituicao
  departamento
}

// Pré-requisito entre avaliações: ex.: Produtividade exige Umidade (conversão a 13%).
model ModeloAvaliacaoPrereq {
  modeloId       String
  prerequisitoId String
  modelo         ModeloAvaliacao @relation("ModeloPrereqs", fields: [modeloId], references: [id], onDelete: Cascade)
  prerequisito   ModeloAvaliacao @relation("ModeloRequeridoPor", fields: [prerequisitoId], references: [id], onDelete: Cascade)

  @@id([modeloId, prerequisitoId])
  @@index([prerequisitoId])
}

// Pré-requisito de uma avaliação sobre uma ATIVIDADE: ex.: Produtividade exige a
// atividade Colheita (linhas/comprimento). Cruza os dois catálogos.
model ModeloAvaliacaoPrereqAtividade {
  modeloAvaliacaoId String
  modeloAtividadeId String
  modeloAvaliacao   ModeloAvaliacao @relation("AvalReqAtiv", fields: [modeloAvaliacaoId], references: [id], onDelete: Cascade)
  modeloAtividade   ModeloAtividade @relation("AtivReqPorAval", fields: [modeloAtividadeId], references: [id], onDelete: Cascade)

  @@id([modeloAvaliacaoId, modeloAtividadeId])
  @@index([modeloAtividadeId])
}

// Conjunto nomeado de avaliações coletadas juntas (ex.: "Colheita" = Umidade+PMG+Produtividade).
// Reutilizável e escopado como o catálogo. Ver demanda de coleta agrupada (B).
model GrupoColeta {
  id             String  @id @default(cuid())
  nome           String
  descricao      String?
  escopo         EscopoModelo @default(instituicao)
  instituicaoId  String?
  departamentoId String?
  ativo          Boolean @default(true)
  createdAt      DateTime @default(now())

  instituicao   Instituicao?  @relation(fields: [instituicaoId], references: [id])
  departamento  Departamento? @relation(fields: [departamentoId], references: [id])
  itens         GrupoColetaItem[]
  avaliacoes    Avaliacao[]

  @@index([instituicaoId])
  @@index([departamentoId])
}

model GrupoColetaItem {
  id       String @id @default(cuid())
  grupoId  String
  modeloId String
  ordem    Int    @default(0)
  grupo    GrupoColeta     @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  modelo   ModeloAvaliacao @relation(fields: [modeloId], references: [id], onDelete: Cascade)

  @@unique([grupoId, modeloId])
}

// ----------------------- Catálogo de atividades (Macro C) -----------------------
// Atividade = registro GERAL do experimento (não por parcela). Pode ser de ação
// (sem coleta) ou com apontamento (campos parametrizados). Multi-escopo como o
// catálogo de avaliações. NÃO confundir com o cadastro simples `Atividade`
// (nome+valorVenda) usado em TratamentoProduto.
// Ver SDD/04-design-detalhado/08-catalogo-avaliacoes.md (Demanda C).
model ModeloAtividade {
  id                   String  @id @default(cuid())
  nome                 String
  descricao            String? @db.Text
  tipo                 TipoAtividade @default(acao)
  metodologiaRelatorio String? @db.Text
  escopo               EscopoModelo @default(sistema)
  instituicaoId        String?
  departamentoId       String?
  ativo                Boolean @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  instituicao   Instituicao?  @relation(fields: [instituicaoId], references: [id])
  departamento  Departamento? @relation(fields: [departamentoId], references: [id])
  campos        ModeloAtividadeCampo[]
  atividades    AtividadeExperimento[]
  requeridaPorAvaliacao ModeloAvaliacaoPrereqAtividade[] @relation("AtivReqPorAval")

  @@index([escopo])
  @@index([instituicaoId])
  @@index([departamentoId])
}

enum TipoAtividade {
  acao
  apontamento
}

// Campo parametrizado de uma atividade com apontamento (ex.: CO2 → vento, umidade, data).
model ModeloAtividadeCampo {
  id          String @id @default(cuid())
  modeloId    String
  rotulo      String
  tipo        TipoCampo @default(numero)
  unidade     String?
  obrigatorio Boolean @default(false)
  ordem       Int     @default(0)
  modelo      ModeloAtividade @relation(fields: [modeloId], references: [id], onDelete: Cascade)

  @@index([modeloId])
}

enum TipoCampo {
  numero
  texto
  data
  booleano
}

// Registro de uma atividade no experimento (nível experimento, não por parcela).
model AtividadeExperimento {
  id            String @id @default(cuid())
  experimentoId String
  modeloId      String?
  nome          String
  tipo          TipoAtividade @default(acao)
  data          DateTime?
  responsavel   String?
  obs           String? @db.Text
  status        String?
  ordem         Int     @default(0)
  createdAt     DateTime @default(now())
  experimento   Experimento      @relation(fields: [experimentoId], references: [id], onDelete: Cascade)
  modelo        ModeloAtividade? @relation(fields: [modeloId], references: [id])
  valores       AtividadeApontamentoValor[]

  @@index([experimentoId])
  @@index([modeloId])
}

// Valor de um campo de apontamento de uma atividade do experimento.
model AtividadeApontamentoValor {
  id          String @id @default(cuid())
  atividadeId String
  campoId     String?            // ref. ao ModeloAtividadeCampo (quando veio do modelo)
  rotulo      String             // snapshot do rótulo
  valorNum    Float?
  valorTexto  String?
  valorData   DateTime?
  valorBool   Boolean?
  atividade   AtividadeExperimento @relation(fields: [atividadeId], references: [id], onDelete: Cascade)

  @@index([atividadeId])
}

model AvaliacaoDado {
  id                 String @id @default(cuid())
  avaliacaoId        String
  parcelaId          String
  numAmostra         Int     @default(1)
  // Valor BRUTO coletado no campo. A produtividade (kg/ha) é apresentada no relatório.
  valorColetado      Float?
  // Apontamentos da ATIVIDADE de colheita (RN-PROD): registrados no momento da atividade.
  numLinhasColhidas  Int?
  comprimentoColhidoM Float?
  areaUtilM2         Float?
  obs                String? @db.Text
  status             String?
  fotoUrl            String?
  origem             OrigemColeta @default(web)
  dispositivoId      String?
  syncedAt           DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  deletedAt          DateTime?

  avaliacao          Avaliacao @relation(fields: [avaliacaoId], references: [id], onDelete: Cascade)
  parcela            Parcela   @relation(fields: [parcelaId], references: [id])

  @@unique([avaliacaoId, parcelaId, numAmostra])
}

enum OrigemColeta {
  web
  mobile
}

// -------------------- Compartilhamento / Ordem de Serviço ---------------- 

model ExperimentoCompartilhamento {
  id             String @id @default(cuid())
  experimentoId  String
  userId         String?
  convidadoEmail String?
  nivel          NivelCompartilhamento @default(input)
  aceito         Boolean @default(false)
  token          String? @unique
  createdAt      DateTime @default(now())
  experimento    Experimento @relation(fields: [experimentoId], references: [id], onDelete: Cascade)
  user           User?       @relation("CompartilhadoCom", fields: [userId], references: [id])

  @@index([userId])
}

enum NivelCompartilhamento {
  input
  edit
}

model OrdemServico {
  id            String @id @default(cuid())
  experimentoId String
  status        StatusOS @default(rascunho)
  createdAt     DateTime @default(now())
  experimento   Experimento @relation(fields: [experimentoId], references: [id])
  aprovacoesInternas AprovacaoOSInterna[]
  aprovacaoCliente   AprovacaoCliente?
}

enum StatusOS {
  rascunho
  aguardando_aprovacao_interna
  aguardando_aprovacao_cliente
  aprovada
  recusada
}

model AprovadorInstituicao {
  id            String @id @default(cuid())
  instituicaoId String
  userId        String
  ativo         Boolean @default(true)
  instituicao   Instituicao @relation(fields: [instituicaoId], references: [id])
  user          User        @relation(fields: [userId], references: [id])

  @@unique([instituicaoId, userId])
}

model AprovacaoOSInterna {
  id             String @id @default(cuid())
  ordemServicoId String
  aprovadorUserId String
  decisao        Decisao
  motivo         String?
  at             DateTime @default(now())
  ordemServico   OrdemServico @relation(fields: [ordemServicoId], references: [id], onDelete: Cascade)
}

model AprovacaoCliente {
  id             String @id @default(cuid())
  ordemServicoId String @unique
  clienteEmail   String
  token          String @unique
  decisao        Decisao @default(pendente)
  motivo         String?
  decididoEm     DateTime?
  ip             String?
  ordemServico   OrdemServico @relation(fields: [ordemServicoId], references: [id], onDelete: Cascade)
}

enum Decisao {
  pendente
  aprovado
  recusado
}

// -------------------------------- Suporte -------------------------------- 

model EmailLog {
  id        String @id @default(cuid())
  tipo      String
  para      String
  assunto   String
  htmlPath  String?
  status    StatusEmail @default(simulado)
  erro      String? @db.Text
  refTipo   String?
  refId     String?
  createdAt DateTime @default(now())
}

enum StatusEmail {
  simulado
  enviado
  erro
}

model StatusHistorico {
  id            String @id @default(cuid())
  experimentoId String
  de            String?
  para          String
  userId        String?
  at            DateTime @default(now())
  experimento   Experimento @relation(fields: [experimentoId], references: [id], onDelete: Cascade)
}
