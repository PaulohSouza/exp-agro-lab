# Banco (dev local). Não versionar o .env real.
DATABASE_URL="mysql://USUARIO:SENHA@127.0.0.1:3306/expagrolab_dev"

PORT=3001

# E-mail (espelha o SAGRE: blastula → nodemailer)
EMAIL_ENABLED=true
SIMULATE_SEND=true                 # true = renderiza HTML em arquivo, não envia
SIMULATE_OUTPUT_DIR=./email-previews
EMAIL_USER="notification@exemplo.com"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_PASSWORD=""                   # app password (só quando SIMULATE_SEND=false)
EMAIL_BASE_URL="http://localhost:3000"
